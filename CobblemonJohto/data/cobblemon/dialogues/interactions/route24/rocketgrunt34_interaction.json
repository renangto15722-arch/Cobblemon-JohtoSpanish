{
    "initializationAction": [
        "q.run_command('scoreboard players set ' + q.player.username + ' BattleStart 7');",
        "q.run_command('execute as ' + q.player.username + ' run function johto:tools/forceclick');"
    ],
    "escapeAction": [
        "q.run_command('scoreboard players set ' + q.player.username + ' BattleStart 0');",
        "q.run_command('execute as ' + q.player.username + ' run function johto:tools/forceclick');",
        "q.dialogue.close();"
    ],
    "names": [
        "Rocket Grunt"
    ],
    "speakers": {
        "npc": {
            "name": {
                "type": "expression",
                "expression": "q.npc.name"
            },
            "face": "q.npc.face();"
        }
    },
    "pages": [
        {
            "id": "greeting",
            "speaker": "npc",
            "lines": [
                "¡Oh no! Escondido yo estaba, pero tú me encontrar en un momento! "
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page2');"
                    }
                ]
            }
        },
        {
            "id": "page2",
            "speaker": "npc",
            "lines": [
                "... Yo solo uno de otro país. ¡Aún! Nada grave, ¿vale? "
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page3');"
                    }
                ]
            }
        },
        {
            "id": "page3",
            "speaker": "npc",
            "lines": [
                "¡Pensar yo hice, si cortar la energía, ser gran pánico y mala suerte para gente de aquí! "
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page4');"
                    }
                ]
            }
        },
        {
            "id": "page4",
            "speaker": "npc",
            "lines": [
                "¡Secreto es mi misión, así que decir a ti yo no! "
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page5');"
                    }
                ]
            }
        },
        {
            "id": "page5",
            "speaker": "npc",
            "lines": [
                "¡Pero! Si ganar tú contra mí, hombre yo ser y mi secreto a ti contar."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page6');"
                    }
                ]
            }
        },
        {
            "id": "page6",
            "speaker": "npc",
            "lines": [
                "¿Tú entiendes? ¡Batalla empezar nosotros!"
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "§c⚔ Battle ⚔§r",
                        "value": "battle",
                        "action": [
                            "q.run_command('scoreboard players set ' + q.player.username + ' BattleStart 11');",
                            "q.run_command('execute as ' + q.player.username + ' run function johto:tools/forceclick');",
                            "v.battle = q.npc.start_battle(q.player);"
                        ]
                    },
                    {
                        "text": "No",
                        "value": "no",
                        "action": [
                            "q.run_command('scoreboard players set ' + q.player.username + ' BattleStart 0');",
                            "q.run_command('execute as ' + q.player.username + ' run function johto:tools/forceclick');",
                            "q.dialogue.close();"
                        ]
                    }
                ]
            }
        }
    ]
}