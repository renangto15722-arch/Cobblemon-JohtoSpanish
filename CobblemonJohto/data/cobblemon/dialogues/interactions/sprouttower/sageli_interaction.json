{   "initializationAction": [              
    "q.run_command('scoreboard players set ' + q.player.username + ' BattleStart 3');",
    "q.run_command('execute as ' + q.player.username + ' run function johto:tools/forceclick');"
        ],
    "escapeAction": [              
        "q.run_command('scoreboard players set ' + q.player.username + ' BattleStart 0');",
        "q.run_command('execute as ' + q.player.username + ' run function johto:tools/forceclick');",
        "q.dialogue.close();"
        ],
    "names": ["Troy"],
    "speakers": {
        "npc": {
            "name": {
                "type": "expression",
                "expression": "q.npc.name"
            },
            "face": "q.npc.face();"
        }
    },
    "pages": [
        {
            "id": "greeting",
            "speaker": "npc",
            "lines": ["¡Qué bueno que hayas venido! La Torre Bellsprout es un lugar de entrenamiento. Las personas y los Pokémon ponen a prueba sus lazos para construir juntos un futuro brillante."],
                  "input": {
                      "type": "option",
                      "vertical": false,
                      "options": [
                          {
                              "text": "Next",
                              "value": "next",
                              "action": "q.dialogue.set_page('page2');"
                          }
                      ]
                  }
              },
          {
              "id": "page2",
              "speaker": "npc",
              "lines": [
                  "Yo soy la prueba final. ¡Déjame comprobar los lazos entre tú y tus Pokémon!"
              ],
              "input": {
                  "type": "option",
                  "vertical": false,
                  "options": [
                      {
                          "text": "§c⚔ Battle ⚔§r",
                          "value": "battle",
                          "action": [                           
                                      "q.run_command('scoreboard players set ' + q.player.username + ' BattleStart 11');",
                                      "q.run_command('execute as ' + q.player.username + ' run function johto:tools/forceclick');",
                                      "v.battle = q.npc.start_battle(q.player);"
                              ]
                      },
                      {
                          "text": "No",
                          "value": "no",
                          "action": [              
                              "q.run_command('scoreboard players set ' + q.player.username + ' BattleStart 0');",
                              "q.run_command('execute as ' + q.player.username + ' run function johto:tools/forceclick');",
                              "q.dialogue.close();"]
                          }
                      ]
                  }
              }
        ]
    }