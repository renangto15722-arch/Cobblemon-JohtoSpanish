{
    "initializationAction": [
        "q.run_script('cobblemon:cooldown_check') ? q.dialogue.set_page('on_cooldown') : q.dialogue.set_page('off_cooldown');"
    ],
    "speakers": {
        "npc": {
            "name": {
                "type": "expression",
                "expression": "q.npc.name"
            },
            "face": "q.npc.face();"
        },
        "player": {
            "face": "q.player.face();",
            "name": {
                "type": "expression",
                "expression": "q.player.username"
            }
        }
    },
    "pages": [
        {
            "id": "off_cooldown",
            "speaker": "npc",
            "lines": [
                "¡Hola, el tiempo de espera ya terminó!"
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "§c⚔ Battle ⚔§r",
                        "value": "battle",
                        "action": [
                            "q.dialogue.close();",
                            "v.battle = q.npc.start_battle(q.player);"
                        ]
                    },
                    {
                        "text": "No",
                        "value": "no",
                        "action": "q.dialogue.close();"
                    }
                ]
            }
        },
        {
            "id": "on_cooldown",
            "speaker": "npc",
            "lines": [
                "¡Hola, TÚ estás en tiempo de espera! Tiempo restante actual:",
                {
                    "type": "expression",
                    "expression": "q.run_script('cobblemon:cooldown_remaining_hours')"
                }
            ],
            "input": "q.dialogue.close();"
        }
    ]
}