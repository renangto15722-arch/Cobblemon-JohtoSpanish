{
    "initializationAction": [
        "q.run_command('team join shops ' + q.player.username + '');"
    ],
    "escapeAction": [
        "q.run_command('team join default ' + q.player.username + '');",
        "q.dialogue.close();"
    ],
    "names": [
        "Poké Mart Clerk"
    ],
    "speakers": {
        "npc": {
            "name": "Poké Mart Clerk",
            "face": {
                "type": "artificial",
                "modelType": "npc",
                "identifier": "cobblemon:shopman",
