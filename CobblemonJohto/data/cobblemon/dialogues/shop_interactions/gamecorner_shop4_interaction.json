{
    "initializationAction": [
        "q.run_command('team join Coins ' + q.player.username + '');"
    ],
    "escapeAction": [
        "q.run_command('team join default ' + q.player.username + '');",
        "q.dialogue.close();"
    ],
    "names": [
        "Game Corner Clerk"
    ],
    "speakers": {
        "npc": {
            "name": "Game Corner Clerk",
            "face": {
                "type": "artificial",
                "modelType": "npc",
                "identifier": "cobblemon:shopman",
                "isLeftSide": true
            }
        }
    },
    "pages": [
        {
            "id": "greeting",
            "speaker": "npc",
            "lines": [
               "Cambiamos tus Coins por premios."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Buy",
                        "value": "buy",
                        "action": "q.dialogue.set_page('buy1');"
                    },
                    {
                        "text": "No Thanks",
                        "value": "nothanks",
                        "action": "q.dialogue.set_page('end');"
                    }
                ]
            }
        },
        {
            "id": "buy1",
            "speaker": "npc",
            "lines": [
                "¿Qué premio te gustaría?"
            ],
            "input": {
                "type": "option",
                "vertical": true,
                "options": [
                    {
                        "text": "Silk Scarf",
                        "value": "silkscarf",
                        "action": "q.dialogue.set_page('picksilkscarf');"
                    },
