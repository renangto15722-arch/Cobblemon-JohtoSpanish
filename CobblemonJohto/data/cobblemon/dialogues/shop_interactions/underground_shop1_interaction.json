{
    "initializationAction": [
        "q.run_command('team join shops ' + q.player.username + '');"
    ],
    "escapeAction": [
        "q.run_command('team join default ' + q.player.username + '');",
        "q.dialogue.close();"
    ],
    "names": [
        "Herbal Shop"
    ],
    "speakers": {
        "npc": {
            "name": "Herbal Shop",
            "face": {
                "type": "artificial",
                "modelType": "npc",
                "identifier": "cobblemon:oldlady",
                "isLeftSide": true
            }
        }
    },
    "pages": [
        {
            "id": "greeting",
            "speaker": "npc",
            "lines": [
                "Hola, cariño."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page2');"
                    }
                ]
            }
        },
        {
            "id": "page2",
            "speaker": "npc",
            "lines": [
                "Vendo medicina herbal económica. Son buenas, pero un poco amargas."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page3');"
                    }
                ]
            }
        },
        {
            "id": "page3",
            "speaker": "npc",
            "lines": [
                "A tu Pokémon puede que no le gusten. Jejejeje..."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Buy",
                        "value": "buy",
                        "action": [
                            "q.dialogue.set_page('buy1');"
                        ]
                    },
                    {
                        "text": "No Thanks",
                        "value": "nothanks",
                        "action": "q.dialogue.set_page('end');"
                    }
                ]
            }
        },

        {
            "id": "buy1",
            "speaker": "npc",
            "lines": [
                "¿Qué objeto te gustaría comprar?"
            ],
            "input": {
                "type": "option",
                "vertical": true,
                "options": [
                    {
                        "text": "Heal Powder",
                        "value": "healpowder",
                        "action": "q.dialogue.set_page('pickhealpowder');"
                    },
                    {
                        "text": "Energy Root",
                        "value": "energyroot",
                        "action": "q.dialogue.set_page('pickenergyroot');"
                    },
                    {
                        "text": "Revival Herb",
                        "value": "revivalherb",
                        "action": "q.dialogue.set_page('pickrevivalherb');"
                    }
                ]
            }
        },



        {
            "id": "pickhealpowder",
            "speaker": "npc",
            "lines": [
                "Polvo Curación es un polvo medicinal muy amargo. Cura todos los problemas de estado de un solo Pokémon. Cada uno cuesta $450."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Buy",
                        "value": "buy",
                        "action": [
                            "q.run_command('scoreboard players set ' + q.player.username + ' TriggerCommand 281');",
                            "q.dialogue.set_page('buyend');"
                        ]
                    },
                    {
                        "text": "<< Go Back",
                        "value": "goback",
                        "action": [
                            "q.dialogue.set_page('buy1');"
                        ]
                    }
                ]
            }
        },
        {
            "id": "pickenergypowder",
            "speaker": "npc",
            "lines": [
                "Polvo Energía es un polvo medicinal muy amargo. Restaura 50 puntos de PS de un Pokémon. Cada uno cuesta $500."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Buy",
                        "value": "buy",
                        "action": [
                            "q.run_command('scoreboard players set ' + q.player.username + ' TriggerCommand 282');",
                            "q.dialogue.set_page('buyend');"
                        ]
                    },
                    {
                        "text": "<< Go Back",
                        "value": "goback",
                        "action": [
                            "q.dialogue.set_page('buy1');"
                        ]
                    }
                ]
            }
        },
        {
            "id": "pickenergyroot",
            "speaker": "npc",
            "lines": [
                "Raíz Energía es una raíz muy amarga. Restaura 120 puntos de PS de un Pokémon. Cada una cuesta $800."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Buy",
                        "value": "buy",
                        "action": [
                            "q.run_command('scoreboard players set ' + q.player.username + ' TriggerCommand 283');",
                            "q.dialogue.set_page('buyend');"
                        ]
                    },
                    {
                        "text": "<< Go Back",
                        "value": "goback",
                        "action": [
                            "q.dialogue.set_page('buy1');"
                        ]
                    }
                ]
            }
        },
        {
            "id": "pickrevivalherb",
            "speaker": "npc",
            "lines": [
                "Hierba Revivir es una hierba medicinal muy amarga. Revive a un Pokémon debilitado y restaura todos sus PS. Cada una cuesta $2800."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Buy",
                        "value": "buy",
                        "action": [
                            "q.run_command('scoreboard players set ' + q.player.username + ' TriggerCommand 284');",
                            "q.dialogue.set_page('buyend');"
                        ]
                    },
                    {
                        "text": "<< Go Back",
                        "value": "goback",
                        "action": [
                            "q.dialogue.set_page('buy1');"
                        ]
                    }
                ]
            }
        },

        
        {
            "id": "buyend",
            "speaker": "npc",
            "lines": [
                "Vuelve por aquí alguna vez."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Close",
                        "value": "close",
                        "action": [
                            "q.run_command('team join default ' + q.player.username + '');",
                            "q.dialogue.close();"
                        ]
                    }
                ]
            }
        },
        {
            "id": "end",
            "speaker": "npc",
            "lines": [
                "Vuelve por aquí alguna vez."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Close",
                        "value": "close",
                        "action": [
                            "q.run_command('team join default ' + q.player.username + '');",
                            "q.dialogue.close();"
                        ]
                    }
                ]
            }
        }
    ]
}