            "id": "greeting",
            "speaker": "npc",
            "lines": [
                "¡Bienvenido al Servicio de Canje! ¿Te gustaría cambiar tus BP por algunos premios?"
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Buy",
                        "value": "buy",
                        "action": "q.dialogue.set_page('buy1');"
                    },
                    {
                        "text": "No Thanks",
                        "value": "nothanks",
                        "action": "q.dialogue.set_page('end');"
                    }
                ]
            }
        },
        {
            "id": "buy1",
            "speaker": "npc",
            "lines": [
                "¿Qué objeto te gustaría comprar?"
            ],
            "input": {
                "type": "option",
                "vertical": true,
                "options": [
                    {
                        "text": "Power Bracer",
                        "value": "powerbracer",
                        "action": "q.dialogue.set_page('pickpowerbracer');"
                    },
                    {
                        "text": "Power Belt",
                        "value": "powerbelt",
