{   
    "initializationAction": [              
        "q.run_command('tag ' + q.player.username + ' add InDialogue');"
            ],
    "escapeAction": [],
    "speakers": {
        "npc": {
          "name": "Mom",
          "face": {
            "type": "artificial",
            "modelType": "npc",
            "identifier": "cobblemon:oldlady",
            "isLeftSide": true
          }
        },
        "player": {
            "face": "q.player.face();",
            "name": {
                "type": "expression",
                "expression": "q.player.username"
            }
        }
      },
    "pages": [
        {
            "id": "greeting",
            "speaker": "npc",
            "lines": [
                "¡Oh, ya estás despierto!"
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page2');"
                    }
                ]
            }
        },
        {
            "id": "page2",
            "speaker": "npc",
            "lines": [
                "Nuestro vecino, el Profesor Elm, te estaba buscando."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page3');"
                    }
                ]
            }
        },
        {
            "id": "page3",
            "speaker": "npc",
            "lines": [
                "Dijo que quería que hicieras algo por él."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Close",
                        "value": "close",
                        "action": [
                            "q.dialogue.close();",
                            "q.run_command('tag ' + q.player.username + ' add Dialogue2');",
                            "q.run_command('tag ' + q.player.username + ' remove InDialogue');"
                            ]
                    }
                ]
            }
        }
        ]
    }