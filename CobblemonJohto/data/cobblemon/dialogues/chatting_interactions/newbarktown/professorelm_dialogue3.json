{   
    "initializationAction": [              
        "q.run_command('tag ' + q.player.username + ' add InDialogue');"
            ],

    "escapeAction": [],
    "names": ["Professor Elm"],
    "speakers": {
        "npc": {
          "name": "Professor Elm",
          "face": {
            "type": "artificial",
            "modelType": "npc",
            "identifier": "cobblemon:professorelm",
            "isLeftSide": true
          }
        }
      },
    "pages": [
        {
            "id": "greeting",
            "speaker": "npc",
            "lines": [
                "¡Ahí estás!"
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page2');"
                    }
                ]
            }
        },
        {
            "id": "page2",
            "speaker": "npc",
            "lines": [
                "Necesitaba pedirte un favor."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page3');"
                    }
                ]
            }
        },
        {
            "id": "page3",
            "speaker": "npc",
            "lines": [
                "Tengo un conocido llamado Mr. Pokémon."
