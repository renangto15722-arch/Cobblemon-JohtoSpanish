{   
    "initializationAction": [
        "q.run_command('tag ' + q.player.username + ' add InDialogue');"
    ],
    "escapeAction": [],
    "speakers": {
        "npc": {
          "name": "     ",
          "face": {
            "type": "artificial",
            "modelType": "npc",
            "identifier": "cobblemon:schoolkid",
            "isLeftSide": true
          }
        }
      },
    "pages": [
        {
            "id": "greeting",
            "speaker": "npc",
            "lines": [
                "El Farfetch'd que corta árboles para hacer carbón se me escapó."
            ],
            "input": {
                "type": "option",
