{   
    "speakers": {
        "npc": {
          "name": "Battle Tower Clerk",
          "face": {
            "type": "artificial",
            "modelType": "npc",
            "identifier": "cobblemon:shopman",
            "isLeftSide": true
          }
        }
      },
    "pages": [
        {
            "id": "greeting",
            "speaker": "npc",
            "lines": [
                "Lo siento, ¡parece que alguien está usando nuestra última sala en este momento!"
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page2');"
                    }
                ]
            }
        },
        {
            "id": "page2",
            "speaker": "npc",
            "lines": [
                "Puedes verlos desde el mirador, ¡vuelve aquí para unirte cuando terminen!"
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Close",
                        "value": "close",
                        "action": [
                            "q.dialogue.close();"
                            ]
                    }
                ]
            }
        }
        ]
    }