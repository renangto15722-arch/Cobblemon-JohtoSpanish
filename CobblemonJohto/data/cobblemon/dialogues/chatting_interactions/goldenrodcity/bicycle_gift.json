{   
    "speakers": {
        "npc": {
          "name": "Bicycle Clerk",
          "face": {
            "type": "artificial",
            "modelType": "npc",
            "identifier": "cobblemon:blacksmith",
            "isLeftSide": true
          }
        }
      },
    "pages": [
        {
            "id": "greeting",
            "speaker": "npc",
            "lines": [
                "...suspiro..."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page2');"
                    }
                ]
            }
        },
        {
            "id": "page2",
            "speaker": "npc",
            "lines": [
                "Me mudé aquí, pero no puedo vender mis bicicletas. ¿Por qué será?"
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page3');"
                    }
                ]
            }
        },
        {
            "id": "page3",
            "speaker": "npc",
            "lines": [
                "¿Podrías montar una bicicleta y hacerme publicidad?"
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Yes",
                        "value": "yes",
                        "action": "q.dialogue.set_page('page4');"
                    },
                    {
                        "text": "No",
                        "value": "no",
                        "action": "q.dialogue.set_page('page9');"
                    }
                ]
            }
        },
        {
            "id": "page4",
            "speaker": "npc",
            "lines": [
                "¿En serio? ¡Genial!"
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page5');"
                    }
                ]
            }
        },
        {
            "id": "page5",
            "speaker": "npc",
            "lines": [
                "Dame tu nombre y número de teléfono, y te prestaré una bicicleta."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": [
                            "q.run_command('execute as ' + q.player.username + ' run function johto:spawn/bicycle');",
                            "q.run_command('execute as ' + q.player.username + ' run tag @s add Dialogue23');",
                            "q.run_command('execute as ' + q.player.username + ' run playsound minecraft:entity.experience_orb.pickup ambient @s ~ ~ ~ 1 1 1');",
                            "q.dialogue.set_page('page6');"
                        ]
                    }
                ]
            }
        },
        {
            "id": "page6",
            "speaker": "npc",
            "lines": [
                "La tienda principal está en Ciudad Celeste, de vuelta en Kanto."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page7');"
                    }
                ]
            }
        },
        {
            "id": "page7",
            "speaker": "npc",
            "lines": [
                "¡Saluda al encargado de la tienda si vas por allí!"
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page8');"
                    }
                ]
            }
        },
        {
            "id": "page8",
            "speaker": "npc",
            "lines": [
                "¡Nuestras bicicletas son de primera! ¡También puedes montarlas en Kanto!"
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Close",
                        "value": "close",
                        "action": [
                            "q.dialogue.close();"
                            ]
                    }
                ]
            }
        },
        {
            "id": "page9",
            "speaker": "npc",
            "lines": [
                "Suspiro... Ay, la bondad de la gente..."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Close",
                        "value": "close",
                        "action": [
                            "q.dialogue.close();"
                            ]
                    }
                ]
            }
        }
        ]
    }