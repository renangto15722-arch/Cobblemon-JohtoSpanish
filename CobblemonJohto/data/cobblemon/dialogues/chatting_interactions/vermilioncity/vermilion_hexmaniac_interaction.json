                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page13');"
                    }
                ]
            }
        },
        {
            "id": "page13",
            "speaker": "npc",
            "lines": [
                "¡Te he entretenido demasiado! Gracias por escucharme."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page14');"
                    }
                ]
            }
        },
        {
            "id": "page14",
            "speaker": "npc",
            "lines": [
                "¡Quiero darte este regalo!"
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page15');"
                    }
                ]
            }
        },
        {
            "id": "page15",
            "speaker": "npc",
            "lines": [
                "Es un Caramelo Raro que hace más fuertes a los Pokémon. "
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page16');"
                    }
                ]
            }
        },
        {
            "id": "page16",
            "speaker": "npc",
            "lines": [
                "Prefiero hacer más fuertes a mis Pokémon combatiendo, así que puedes quedártelo."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Close",
                        "value": "close",
                        "action": [
                            "q.run_command('execute as ' + q.player.username + ' run function johto:triggers/itemlootgive');",
                            "q.dialogue.close();"
                            ]
                    }
                ]
            }
        }
        ]
    }