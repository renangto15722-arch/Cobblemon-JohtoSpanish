{   
    "speakers": {
        "npc": {
          "name": "Fan Club Chairman",
          "face": {
            "type": "artificial",
            "modelType": "npc",
            "identifier": "cobblemon:hexmaniac",
            "isLeftSide": true
          }
        }
      },
      "pages": [
        {
            "id": "greeting",
            "speaker": "npc",
            "lines": [
                "Soy el Presidente del Club de Fans Pokémon. "
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page2');"
                    }
                ]
            }
        },
        {
            "id": "page2",
            "speaker": "npc",
            "lines": [
                "He criado más de 150 Pokémon. Soy muy exigente con los Pokémon. "
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page3');"
                    }
                ]
            }
        },
        {
            "id": "page3",
            "speaker": "npc",
            "lines": [
                "¿Viniste solo para oír hablar de mis Pokémon?"
