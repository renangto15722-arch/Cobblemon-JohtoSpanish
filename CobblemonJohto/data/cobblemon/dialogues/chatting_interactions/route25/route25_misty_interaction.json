{   
    "initializationAction": [              
        "q.run_command('tag ' + q.player.username + ' add InDialogue');"
            ],
    "speakers": {
        "npc": {
          "name": "Misty",
          "face": {
            "type": "artificial",
            "modelType": "npc",
            "identifier": "cobblemon:misty",
            "isLeftSide": true
          }
        }
      },
      "pages": [
        {
            "id": "greeting",
            "speaker": "npc",
            "lines": [
                "¡Ay! ¿Por qué tuviste que aparecer y molestarnos justo ahora?"
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page2');"
                    }
                ]
            }
        },
        {
            "id": "page2",
            "speaker": "npc",
            "lines": [
                "¿Sabes cómo llaman a la gente como tú?"
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page3');"
                    }
                ]
            }
        },
        {
            "id": "page3",
            "speaker": "npc",
            "lines": [
                "¡Plagas! Me oíste bien, ¡plaga! ..."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page4');"
                    }
                ]
            }
        },
        {
            "id": "page4",
            "speaker": "npc",
            "lines": [
                "...¡Oh! Esas Medallas que tienes... ¿Son Medallas de Gimnasio de Johto?"
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page5');"
                    }
                ]
            }
        },
        {
            "id": "page5",
            "speaker": "npc",
            "lines": [
                "Si tienes ocho, debes de ser bueno."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page6');"
                    }
                ]
            }
        },
        {
            "id": "page6",
            "speaker": "npc",
            "lines": [
                "Muy bien, entonces. Ven al Gimnasio de Ciudad Celeste."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page7');"
                    }
                ]
            }
        },
        {
            "id": "page7",
            "speaker": "npc",
            "lines": [
                "Soy Misty, la Líder de Gimnasio de Ciudad Celeste. Nos vemos allí."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Close",
                        "value": "close",
                        "action": [
                            "q.run_command('tag ' + q.player.username + ' add Dialogue113');",
                            "q.run_command('execute as ' + q.player.username + ' run particle cloud -3060 64 956 1 1 1 1 100');",
                            "q.run_command('execute as ' + q.player.username + ' run tp @e[x=-3060,y=63,z=956,dy=3,type=cobblemon:npc] 10000000 -50000 -10000000');",
                            "q.run_command('tag ' + q.player.username + ' remove InDialogue');",
                            "q.dialogue.close();"
                            ]
                    }
                ]
            }
        }
        ]
    }