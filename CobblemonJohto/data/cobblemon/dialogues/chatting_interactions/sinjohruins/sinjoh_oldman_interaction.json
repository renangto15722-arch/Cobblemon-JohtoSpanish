{   
    "speakers": {
        "npc": {
          "name": "     ",
          "face": {
            "type": "artificial",
            "modelType": "npc",
            "identifier": "cobblemon:oldman",
            "isLeftSide": true
          }
        }
      },
      "pages": [
        {
            "id": "greeting",
            "speaker": "npc",
            "lines": [
                "Pareces totalmente fuera de lugar, ni siquiera sabes por qué estás aquí."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page2');"
                    }
                ]
            }
        },
        {
            "id": "page2",
            "speaker": "npc",
            "lines": [
                "¿Quieres que mi Abra use un poder especial para llevarte a casa?"
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Leave Ruins",
                        "value": "battle",
                        "action": [                           
                                    "q.run_command('scoreboard players set ' + q.player.username + ' TriggerCommand 26');",
                                    "q.dialogue.close();"
                            ]
                    },
                    {
                        "text": "No Thanks",
                        "value": "no",
                        "action": "q.dialogue.set_page('nothanks');"
                        }
                    ]
                }
        },


        {
            "id": "nothanks",
            "speaker": "npc",
            "lines": [
                "¡Avísame si cambias de idea!"
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Close",
                        "value": "close",
                        "action": [
                            "q.dialogue.close();"
                            ]
                    }
                ]
            }
        }
        ]
    }