{
    "speakers": {
        "npc": {
          "name": "Nurse Joy",
          "face": {
            "type": "artificial",
            "modelType": "npc",
            "identifier": "cobblemon:nursejoy",
            "isLeftSide": true
          }
        }
      },
    "pages": [
        {
            "id": "greeting",
            "speaker": "npc",
            "lines": [
                "¿Listo para luchar contra otro entrenador?"
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Yes",
                        "value": "yes",
                        "action": "q.dialogue.set_page('yes');"
                    },
                    {
                        "text": "Give Up",
                        "value": "giveup",
                        "action": "q.dialogue.set_page('giveup');"
                    }
                ]
            }
        },
        {
            "id": "yes",
            "speaker": "npc",
            "lines": [
                "¡Prepararé tu próxima batalla!"
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Close",
                        "value": "close",
                        "action": [
                            "q.run_command('scoreboard players set ' + q.player.username + ' TriggerCommand 1');",
                            "q.dialogue.close();"
                            ]
                    }
                ]
            }
        },

        {
            "id": "giveup",
            "speaker": "npc",
            "lines": [
                "¿Seguro que quieres salir de la Torre?"
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Give Up",
                        "value": "giveup",
                        "action": "q.dialogue.set_page('giveupconfirm');"
                    },
                    {
                        "text": "Go Back",
                        "value": "goback",
                        "action": "q.dialogue.set_page('greeting');"
                    }
                ]
            }
        },
        {
            "id": "giveupconfirm",
            "speaker": "npc",
            "lines": [
                "¡Esperamos verte de nuevo!"
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Close",
                        "value": "close",
                        "action": [
                            "q.run_command('execute as ' + q.player.username + ' run tp @s 902 64 67 180 ~');",
                            "q.dialogue.close();"
                            ]
                    }
                ]
            }
        }
        ]
    }