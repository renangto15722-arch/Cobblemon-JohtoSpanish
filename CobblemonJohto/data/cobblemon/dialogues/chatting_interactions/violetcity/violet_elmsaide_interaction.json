{   
    "speakers": {
        "npc": {
          "name": "Elm's Aide",
          "face": {
            "type": "artificial",
            "modelType": "npc",
            "identifier": "cobblemon:scientistm",
            "isLeftSide": true
          }
        }
      },
      "pages": [
        {
            "id": "greeting",
            "speaker": "npc",
            "lines": [
        {
            "type": "expression",
            "expression": "'' + q.player.username + ', cuánto tiempo sin verte. El Profesor Elm me pidió que te buscara.';"
        }
    ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page2');"
                    }
                ]
            }
        },
        {
            "id": "page2",
            "speaker": "npc",
            "lines": [
                "Tiene otro favor que pedir. ¿Te llevarías el Pokémon Egg?"
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page3');"
                    }
                ]
            }
        },
        {
            "id": "page3",
            "speaker": "npc",
            "lines": [
                "Descubrimos que un Pokémon no eclosiona hasta que crece dentro del Egg."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page4');"
                    }
                ]
            }
        },
        {
            "id": "page4",
            "speaker": "npc",
            "lines": [
                "También tiene que estar con otros Pokémon activos para eclosionar."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page5');"
                    }
                ]
            }
        },
        {
            "id": "page5",
            "speaker": "npc",
            "lines": [
        {
            "type": "expression",
            "expression": "'' + q.player.username + ', eres la única persona en quien podemos confiar.';"
        }
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page6');"
                    }
                ]
            }
        },
        {
            "id": "page6",
            "speaker": "npc",
            "lines": [
                "¡Yo vuelvo al laboratorio!"
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Close",
                        "value": "close",
                        "action": [
                            "q.run_command('execute as ' + q.player.username + ' run function johto:triggers/itemlootgive');",
                            "q.dialogue.close();"
                            ]
                    }
                ]
            }
        }
        ]
    }