{   
    "speakers": {
        "npc": {
          "name": "     ",
          "face": {
            "type": "artificial",
            "modelType": "npc",
            "identifier": "cobblemon:teacher",
            "isLeftSide": true
          }
        }
      },
    "pages": [
        {
            "id": "greeting",
            "speaker": "npc",
            "lines": [
                "¡Presta atención, por favor!"
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page2');"
                    }
                ]
            }
        },
        {
            "id": "page2",
            "speaker": "npc",
            "lines": [
                "...Uy, tengo que dejar de pensar como una maestra todo el tiempo."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page3');"
                    }
                ]
            }
        },
        {
            "id": "page3",
            "speaker": "npc",
            "lines": [
                "Debes de ser un entrenador Pokémon. Como te esfuerzas tanto, quiero que tengas esto."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page4');"
                    }
                ]
            }
        },
        {
            "id": "page4",
            "speaker": "npc",
            "lines": [
                "Deja que un Pokémon lleve esa Quick Claw. A veces atacará primero durante el combate."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Close",
                        "value": "close",
                        "action": [
                            "q.run_command('execute as ' + q.player.username + ' run function johto:triggers/itemlootgive');",
                            "q.dialogue.close();"
                            ]
                    }
                ]
            }
        }
        ]
    }