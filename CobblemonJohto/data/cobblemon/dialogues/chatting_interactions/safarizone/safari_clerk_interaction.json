{   
    "speakers": {
        "npc": {
          "name": "Safari Clerk",
          "face": {
            "type": "artificial",
            "modelType": "npc",
            "identifier": "cobblemon:shopman",
            "isLeftSide": true
          }
        }
      },
      "pages": [
        {
            "id": "greeting",
            "speaker": "npc",
            "lines": [
                "¡Bienvenido a la Zona Safari! ¡Captura aquí Pokémon que no se encuentran en ningún otro lugar!"
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page2');"
                    }
                ]
            }
        },
        {
            "id": "page2",
            "speaker": "npc",
            "lines": [
                "¡Una vez que inicies una sesión, puedes organizar los biomas como quieras!"
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page3');"
                    }
                ]
            }
        },
        {
            "id": "page3",
            "speaker": "npc",
            "lines": [
                "Recibes 64 Safari Balls gratis, pero también puedes usar las que traigas contigo."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page4');"
                    }
                ]
            }
        },
        {
            "id": "page4",
            "speaker": "npc",
            "lines": [
                "No hay límite de tiempo ni de pasos, solo una entrada de $500, ¡así que ponte a cazar hoy mismo!"
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Start Safari!",
                        "value": "battle",
                        "action": [                           
                                    "q.run_command('scoreboard players set ' + q.player.username + ' TriggerCommand 22');",
                                    "q.dialogue.close();"
                            ]
                    },
                    {
                        "text": "No Thanks",
                        "value": "no",
                        "action": "q.dialogue.set_page('nothanks');"
                        }
                    ]
                }
        },


        {
            "id": "nothanks",
            "speaker": "npc",
            "lines": [
                "¡Vuelve pronto!"
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Close",
                        "value": "close",
                        "action": [
                            "q.dialogue.close();"
                            ]
                    }
                ]
            }
        }
        ]
    }