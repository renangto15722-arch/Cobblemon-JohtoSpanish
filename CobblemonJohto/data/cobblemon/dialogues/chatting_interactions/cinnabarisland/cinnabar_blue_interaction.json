{   
    "speakers": {
        "npc": {
          "name": "Blue",
          "face": {
            "type": "artificial",
            "modelType": "npc",
            "identifier": "cobblemon:blue",
            "isLeftSide": true
          }
        }
      },
    "pages": [
        {
            "id": "greeting",
            "speaker": "npc",
            "lines": [
                "¿Quién eres tú?"
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page2');"
                    }
                ]
            }
        },
        {
            "id": "page2",
            "speaker": "npc",
            "lines": [
                "Me llamo Blue. Una vez fui el Campeón de Kanto."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page3');"
                    }
                ]
            }
        },
        {
            "id": "page3",
            "speaker": "npc",
            "lines": [
                "Aunque duró poco gracias a Red..."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page4');"
                    }
                ]
            }
        },
        {
            "id": "page4",
            "speaker": "npc",
            "lines": [
                "En fin, echa un buen vistazo a tu alrededor..."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page5');"
                    }
                ]
            }
        },
        {
            "id": "page5",
            "speaker": "npc",
            "lines": [
                "Un volcán entra en erupción y, así sin más, un pueblo entero desaparece."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page6');"
                    }
                ]
            }
        },
        {
            "id": "page6",
            "speaker": "npc",
            "lines": [
                "Podemos seguir ganando y perdiendo en Pokémon, pero si la naturaleza apenas se mueve, podemos ser arrasados en un segundo..."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page7');"
                    }
                ]
            }
        },
        {
            "id": "page7",
            "speaker": "npc",
            "lines": [
                "Así son las cosas..."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page8');"
                    }
                ]
            }
        },
        {
            "id": "page8",
            "speaker": "npc",
            "lines": [
                "Pero, en fin, sigo siendo un Entrenador."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page9');"
                    }
                ]
            }
        },
        {
            "id": "page9",
            "speaker": "npc",
            "lines": [
                "Si veo a un oponente fuerte, me dan ganas de combatir."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page10');"
                    }
                ]
            }
        },
        {
            "id": "page10",
            "speaker": "npc",
            "lines": [
                "Si quieres combatir contra mí... de verdad, ven al Gimnasio de Ciudad Verde."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page11');"
                    }
                ]
            }
        },
        {
            "id": "page11",
            "speaker": "npc",
            "lines": [
                "¡Te estaré esperando!"
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Close",
                        "value": "close",
                        "action": [
                            "q.run_command('execute as ' + q.player.username + ' run tag @s add Dialogue235');",
                            "q.run_command('particle cloud -1697 69 -854 1 1 1 1 25');",
                            "q.run_command('tp @e[x=-1697,y=69,z=-854,dy=3,dz=1,type=cobblemon:npc] 10000000 -50000 -10000000');",
                            "q.dialogue.close();"
                            ]
                    }
                ]
            }
        }
        ]
    }