{   
    "initializationAction": [              
        "q.run_command('tag ' + q.player.username + ' add InDialogue');"
            ],
    "speakers": {
        "npc": {
          "name": "Chuck's Wife",
          "face": {
            "type": "artificial",
            "modelType": "npc",
            "identifier": "cobblemon:pokefanf",
            "isLeftSide": true
          }
        }
      },
    "pages": [
        {
            "id": "greeting",
            "speaker": "npc",
            "lines": [
                "¡Esa es la Medalla del Gimnasio de Ciudad Orquídea! Entonces deberías llevarte este HM."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page2');"
                    }
                ]
            }
        },
        {
            "id": "page2",
            "speaker": "npc",
            "lines": [
                "Podrás usar Fly para ir al instante a cualquier lugar que hayas visitado."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page3');"
                    }
                ]
            }
        },
        {
            "id": "page3",
            "speaker": "npc",
            "lines": [
                "Mi esposo perdió contra ti, así que necesita entrenar más duro."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page4');"
                    }
                ]
            }
        },
        {
            "id": "page4",
            "speaker": "npc",
            "lines": [
                "Eso está bien, porque se estaba poniendo un poco regordete."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Close",
                        "value": "close",
                        "action": [
                            "q.run_command('execute as ' + q.player.username + ' run playsound minecraft:entity.experience_orb.pickup ambient @s ~ ~ ~ 1 1 1');",
                            "q.run_command('execute as ' + q.player.username + ' run function johto:spawn/flyhm');",
                            "q.run_command('execute as ' + q.player.username + ' run tag @s add Dialogue43');",
                            "q.run_command('tag ' + q.player.username + ' remove InDialogue');",
                            "q.dialogue.close();"
                            ]
                    }
                ]
            }
        }
        ]
    }