{ 

    "speakers": {
    "npc": {
        "name": "Frieda",
        "face": {
            "type": "artificial",
            "modelType": "npc",
            "identifier": "cobblemon:pokefanf",
            "isLeftSide": true
        }
    }
      },
    "pages": [
        {
            "id": "greeting",
            "speaker": "npc",
            "lines": [
                "Solo puedes conseguir un ribbon por semana..."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": [
                            "q.dialogue.set_page('page2');"
                        ]
                    }
                ]
            }
        },
        {
            "id": "page2",
            "speaker": "npc",
            "lines": [
                "¡Si quieres otro ribbon, vuelve a buscarme la próxima semana!"
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Close",
                        "value": "close",
                        "action": [
                            "q.run_command('execute as ' + q.player.username + ' run tag @s add RibbonCooldown');",
                            "q.dialogue.close();"
                            ]
                    }
                ]
            }
        }
        ]
    }