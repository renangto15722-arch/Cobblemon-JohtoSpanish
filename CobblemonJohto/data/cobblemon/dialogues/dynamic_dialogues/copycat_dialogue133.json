{   
    "speakers": {
        "player": {
         "face": "q.player.face(true);",
         "name": "Copycat",
         "isLeftSide": true
    },
    "copycat": {
        "name": "Copycat",
        "face": {
            "type": "artificial",
            "modelType": "npc",
            "identifier": "cobblemon:lass",
            "isLeftSide": true
        }
    }
      },
      "escapeAction": [              
        ],
    "pages": [
        {
            "id": "greeting",
            "speaker": "player",
            "lines": [
                "¡Hola! Oí que perdiste tu querido Poke Doll."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page2');"
                    }
                ]
            }
        },
        {
            "id": "page2",
            "speaker": "player",
            "lines": [
                "¿Si lo encuentro, me darás un pase de tren?"
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page3');"
                    }
                ]
            }
        },
        {
            "id": "page3",
            "speaker": "player",
            "lines": [
                "Iré a buscarlo por ti. ¿Crees que lo perdiste cuando fuiste a Ciudad Carmín?"
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page4');"
                    }
                ]
            }
        },
        {
            "id": "page4",
            "speaker": "copycat",
            "lines": [
                "¿Perdón? ¿No debería decidir lo que tienes que hacer?"
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page5');"
                    }
                ]
            }
        },
        {
            "id": "page5",
            "speaker": "copycat",
            "lines": [
                "Pero estoy muy preocupada... ¿Y si alguien lo encuentra?"
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Close",
                        "value": "close",
                        "action": [
                            "q.run_command('execute as ' + q.player.username + ' run tag @s add Dialogue133');",
                            "q.dialogue.close();"
                            ]
                    }
                ]
            }
        }
        ]
    }