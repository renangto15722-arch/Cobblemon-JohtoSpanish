{
    "initializationAction": [
        "q.run_command('tag ' + q.player.username + ' add InDialogue');"
    ],
    "escapeAction": [],
    "speakers": {
        "npc": {
            "name": "Kurt",
            "face": {
                "type": "artificial",
                "modelType": "npc",
                "identifier": "cobblemon:kurt",
                "isLeftSide": true
            }
        }
    },
    "pages": [
        {
            "id": "greeting",
            "speaker": "npc",
            "lines": [
                "¿Hm? ¿Quién eres?"
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page2');"
                    }
                ]
            }
        },
        {
            "id": "page2",
            "speaker": "npc",
            "lines": [
                {
                    "type": "expression",
                    "expression": "'' + q.player.username + ', ¿eh? ¿Quieres que fabrique unas Balls?';"
                }
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page3');"
                    }
                ]
            }
        },
        {
            "id": "page3",
            "speaker": "npc",
            "lines": [
                "Lo siento, pero eso tendrá que esperar. ¿Conoces al Team Rocket?"
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": [
                        "q.dialogue.set_page('page4');"
                    ]
                    }
                ]
            }
        },
        {
            "id": "page4",
            "speaker": "npc",
            "lines": [
                "Ah, no te preocupes. Te lo contaré de todos modos."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page5');"
                    }
                ]
            }
        },
        {
            "id": "page5",
            "speaker": "npc",
            "lines": [
                "El Team Rocket es una banda malvada que usa Pokémon para su trabajo sucio."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page6');"
                    }
                ]
            }
        },
        {
            "id": "page6",
            "speaker": "npc",
            "lines": [
                "Se supone que se disolvieron hace tres años."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page7');"
                    }
                ]
            }
        },
        {
            "id": "page7",
            "speaker": "npc",
            "lines": [
                "En fin, ¡están en el Pozo, cortando Slowpoketails para venderlas!"
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page8');"
                    }
                ]
            }
        },
        {
            "id": "page8",
            "speaker": "npc",
            "lines": [
                "¡Así que voy a darles una lección dolorosa!"
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page9');"
                    }
                ]
            }
        },
        {
            "id": "page9",
            "speaker": "npc",
            "lines": [
                "¡Aguanta, Slowpoke! ¡El viejo Kurt va en camino!"
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Close",
                        "value": "close",
                        "action": [
                            "q.run_command('execute as ' + q.player.username + ' run particle cloud 371 64 -698 1 1 1 1 100');",
                            "q.run_command('execute as ' + q.player.username + ' run playsound flee ambient @s ~ ~ ~ 1 1 1');",
                            "q.run_command('tag ' + q.player.username + ' add Dialogue14');",
                            "q.run_command('tag ' + q.player.username + ' remove InDialogue');",
                            "q.dialogue.close();"
                        ]
                    }
                ]
            }
        }
    ]
}