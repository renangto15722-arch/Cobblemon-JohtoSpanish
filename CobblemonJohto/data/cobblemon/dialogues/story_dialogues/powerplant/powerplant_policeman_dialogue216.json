            "isLeftSide": true
          }
        }
      },
    "pages": [
        {
            "id": "greeting",
            "speaker": "npc",
            "lines": [
                "Acabo de recibir noticias de Ciudad Celeste."
            ],
            "input": {
                "type": "option",
