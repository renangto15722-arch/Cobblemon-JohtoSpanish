{
    "initializationAction": [
        "q.run_command('tag ' + q.player.username + ' add InDialogue');"
    ],
    "escapeAction": [              
        ],
    "speakers": {
        "npc": {
          "name": "Power Plant Manager",
          "face": {
            "type": "artificial",
            "modelType": "npc",
            "identifier": "cobblemon:gentleman",
            "isLeftSide": true
          }
        }
      },
    "pages": [
        {
            "id": "greeting",
            "speaker": "npc",
            "lines": [
                "¡E-e-estoy listo para hacer volar algo!"
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page2');"
                    }
                ]
            }
        },
        {
            "id": "page2",
            "speaker": "npc",
            "lines": [
                "¿Quién se atrevería a robar una pieza del generador? ¡Pasé tantísimo tiempo arreglándolo!"
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page3');"
                    }
                ]
            }
        },
        {
            "id": "page3",
            "speaker": "npc",
            "lines": [
                "¡Si lo atrapo, va a ver lo que puedo hacer con mi Charge Beam!"
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Close",
                        "value": "close",
                        "action": [
                            "q.run_command('tag ' + q.player.username + ' add Dialogue215');",
                            "q.run_command('tag ' + q.player.username + ' remove InDialogue');",
                            "q.dialogue.close();"
                            ]
                    }
                ]
            }
        }
        ]
    }