{
    "initializationAction": [
        "q.run_command('tag ' + q.player.username + ' add InDialogue');"
    ],
    "escapeAction": [              
        ],
    "speakers": {
        "npc": {
          "name": "Rocket Grunt",
          "face": {
            "type": "artificial",
            "modelType": "npc",
            "identifier": "cobblemon:rocketgrunt",
            "isLeftSide": true
          }
        }
      },
    "pages": [
        {
            "id": "greeting",
            "speaker": "npc",
            "lines": [
                "Yo muy ocupado. No tener tiempo para hablar contigo."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page2');"
                    }
                ]
            }
        },
        {
            "id": "page2",
            "speaker": "npc",
            "lines": [
                "No bueno para mí si alguien me ve."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page3');"
                    }
                ]
            }
        },
        {
            "id": "page3",
            "speaker": "npc",
            "lines": [
                "¡Oh no! ¡Ya me viste! ¡Yo cometer gran error!"
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page4');"
                    }
                ]
            }
        },
        {
            "id": "page4",
            "speaker": "npc",
            "lines": [
                "¡Oye, tú! ¿Olvidar que me viste, OK?"
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page5');"
                    }
                ]
            }
        },
        {
            "id": "page5",
            "speaker": "npc",
            "lines": [
                "¿Tú no ver, no oír, no saber nada, OK? ¡Adiós! ¡Adiós a go-go!"
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Close",
                        "value": "close",
                        "action": [
                            "q.run_command('execute as ' + q.player.username + ' run particle cloud -1185 65 743 1 1 1 1 100');",
                            "q.run_command('execute as ' + q.player.username + ' run tp @e[x=-1185,y=64,z=743,dy=3,nbt=!{cobblemon:npc_chatting}] 10000000 -50000 -10000000');",
                            "q.run_command('tag ' + q.player.username + ' add Dialogue217');",
                            "q.run_command('tag ' + q.player.username + ' remove InDialogue');",
                            "q.dialogue.close();"
                            ]
                    }
                ]
            }
        }
        ]
    }