{
    "initializationAction": [
        "q.run_command('tag ' + q.player.username + ' add InDialogue');"
    ],
    "escapeAction": [],
    "speakers": {
        "mrpokemon": {
            "name": "Mr. Pokemon",
            "face": {
                "type": "artificial",
                "modelType": "npc",
                "identifier": "cobblemon:mrpokemon",
                "isLeftSide": true
            }
        },
        "oak": {
            "name": "Professor Oak",
            "face": {
                "type": "artificial",
                "modelType": "npc",
                "identifier": "cobblemon:professoroak",
                "isLeftSide": false
            }
        }
    },
    "pages": [
        {
            "id": "greeting",
            "speaker": "mrpokemon",
            "lines": [
                {
                    "type": "expression",
                    "expression": "'¡Hola, hola! Debes de ser ' + q.player.username + '.';"
                }
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page2');"
                    }
                ]
            }
        },
        {
            "id": "page2",
            "speaker": "mrpokemon",
            "lines": [
                "El Profesor Elm dijo que vendrías."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page3');"
                    }
                ]
            }
        },
        {
            "id": "page3",
            "speaker": "mrpokemon",
            "lines": [
                "Esto es lo que quiero que el Profesor Elm examine."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": [
                        "q.dialogue.set_page('page4');",
                        "q.run_command('execute as ' + q.player.username + ' run function johto:spawn/mysteryegg');",
                        "q.run_command('execute as ' + q.player.username + ' run playsound minecraft:entity.experience_orb.pickup ambient @s ~ ~ ~ 1 1 1');"
                    ]
                    }
                ]
            }
        },
        {
            "id": "page4",
            "speaker": "mrpokemon",
            "lines": [
                "Conozco a una pareja que lleva un servicio de Guardería Pokémon."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page5');"
                    }
                ]
            }
        },
        {
            "id": "page5",
            "speaker": "mrpokemon",
            "lines": [
                "Ellos me dieron ese huevo. Me intrigó, así que le envié una carta al Profesor Elm."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page6');"
                    }
                ]
            }
        },
        {
            "id": "page6",
            "speaker": "mrpokemon",
            "lines": [
                "En cuanto a la evolución Pokémon, el Profesor Elm es la autoridad."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page7');"
                    }
                ]
            }
        },
        {
            "id": "page7",
            "speaker": "mrpokemon",
            "lines": [
                "Incluso el Profesor Oak aquí lo reconoce."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page8');"
                    }
                ]
            }
        },
        {
            "id": "page8",
            "speaker": "mrpokemon",
            "lines": [
                "Si mi suposición es correcta, el Profesor Elm lo sabrá."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page9');"
                    }
                ]
            }
        },
        {
            "id": "page9",
            "speaker": "oak",
            "lines": [
                {
                    "type": "expression",
                    "expression": "'¡Ajá! ¡Así que tú eres ' + q.player.username + '! ¡Soy Oak!';"
                }
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page10');"
                    }
                ]
            }
        },
        {
            "id": "page10",
            "speaker": "oak",
            "lines": [
                "Un investigador Pokémon. Justo estaba visitando a mi viejo amigo Mr. Pokémon."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page11');"
                    }
                ]
            }
        },
        {
            "id": "page11",
            "speaker": "oak",
            "lines": [
                "Escuché que estabas haciendo un recado para el Profesor Elm, así que esperé aquí."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page12');"
                    }
                ]
            }
        },
        {
            "id": "page12",
            "speaker": "oak",
            "lines": [
                "¡Oh! ¿Qué es esto? ¡Un Pokémon raro! Veamos... ¡Hmm, ya veo!"
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page13');"
                    }
                ]
            }
        },
        {
            "id": "page13",
            "speaker": "oak",
            "lines": [
                "Entiendo por qué el Profesor Elm te dio un Pokémon para este recado."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page14');"
                    }
                ]
            }
        },
        {
            "id": "page14",
            "speaker": "oak",
            "lines": [
                "Para investigadores como el Profesor Elm y yo, los Pokémon son nuestros amigos."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page15');"
                    }
                ]
            }
        },
        {
            "id": "page15",
            "speaker": "oak",
            "lines": [
                "Él vio que tratarías a tus Pokémon con amor y cariño."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page16');"
                    }
                ]
            }
        },
        {
            "id": "page16",
            "speaker": "oak",
            "lines": [
                "...¡Ah! Pareces de fiar. ¿Qué te parecería ayudarme?"
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": [
                            "q.dialogue.set_page('page17');",
                            "q.run_command('execute as ' + q.player.username + ' run give @s cobblemon:pokedex_red');",
                            "q.run_command('execute as ' + q.player.username + ' run playsound minecraft:entity.experience_orb.pickup ambient @s ~ ~ ~ 1 1 1');"
                        ]
                    }
                ]
            }
        },
        {
            "id": "page17",
            "speaker": "oak",
            "lines": [
                "¿Ves? Esta es la última versión de la Pokédex."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page18');"
                    }
                ]
            }
        },
        {
            "id": "page18",
            "speaker": "oak",
            "lines": [
                "Registra automáticamente datos de los Pokémon que has visto o capturado."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page19');"
                    }
                ]
            }
        },
        {
            "id": "page19",
            "speaker": "oak",
            "lines": [
                "¡Es una enciclopedia de alta tecnología!"
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page20');"
                    }
                ]
            }
        },
        {
            "id": "page20",
            "speaker": "oak",
            "lines": [
                "¡Ve a conocer muchos tipos de Pokémon y completa esa Pokédex!"
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page21');"
                    }
                ]
            }
        },
        {
            "id": "page21",
            "speaker": "oak",
            "lines": [
                "Pero me he quedado demasiado tiempo. Tengo que ir a Ciudad Trigal para mi programa de radio habitual."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page22');"
                    }
                ]
            }
        },
        {
            "id": "page22",
            "speaker": "mrpokemon",
            "lines": [
                {
                    "type": "expression",
                    "expression": "'' + q.player.username + ', ¡cuento contigo!';"
                }
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page23');"
                    }
                ]
            }
        },
        {
            "id": "page23",
            "speaker": "mrpokemon",
            "lines": [
                "¿Vas a volver con el Profesor Elm?"
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page24');"
                    }
                ]
            }
        },
        {
            "id": "page24",
            "speaker": "mrpokemon",
            "lines": [
                "Toma. Tus Pokémon deberían descansar un poco."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Close",
                        "value": "close",
                        "action": [
                            "q.run_command('execute as ' + q.player.username + ' run pokeheal');",
                            "q.run_command('execute as ' + q.player.username + ' run playsound cobblemon:block.healing_machine.active ambient @s ~ ~ ~ 1 1 1');",
                            "q.run_command('tag ' + q.player.username + ' add Dialogue5');",
                            "q.run_command('tag ' + q.player.username + ' remove InDialogue');",
                            "q.dialogue.close();"
                        ]
                    }
                ]
            }
        }
    ]
}