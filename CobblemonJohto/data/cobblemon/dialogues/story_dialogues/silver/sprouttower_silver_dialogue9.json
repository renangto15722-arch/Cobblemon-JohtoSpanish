{   "initializationAction": [              
    "q.run_command('scoreboard players set ' + q.player.username + ' BattleStart 1');",
    "q.run_command('execute as ' + q.player.username + ' run function johto:tools/forceclick');",
    "q.run_command('tag ' + q.player.username + ' add InDialogue');"
        ],
    "escapeAction": [],
    "speakers": {
        "silver": {
          "name": "Silver",
          "face": {
            "type": "artificial",
            "modelType": "npc",
            "identifier": "cobblemon:silver",
            "isLeftSide": true
          }
        },
        "sage": {
          "name": "Elder Li",
          "face": {
            "type": "artificial",
            "modelType": "npc",
            "identifier": "cobblemon:sage",
            "isLeftSide": false
          }
        }
      },
    "pages": [
        {
            "id": "greeting",
            "speaker": "sage",
            "lines": [
                "Eres realmente hábil como entrenador. Como prometí, aquí tienes tu HM."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page2');"
                    }
                ]
            }
        },
        {
            "id": "page2",
            "speaker": "sage",
            "lines": [
                "Pero déjame decirte esto: deberías tratar mejor a tus Pokémon."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page3');"
                    }
                ]
            }
        },
        {
            "id": "page3",
            "speaker": "sage",
            "lines": [
                "Tu forma de combatir es demasiado brutal. Los Pokémon no son herramientas de guerra..."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page4');"
                    }
                ]
            }
        },
        {
            "id": "page4",
            "speaker": "silver",
            "lines": [
                "... ...¡Bah! Dice ser el Anciano pero es débil. Es lógico."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page5');"
                    }
                ]
            }
        },
        {
            "id": "page5",
            "speaker": "silver",
            "lines": [
                "Jamás perdería ante tontos que parlotean sobre ser amables con los Pokémon."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page6');"
                    }
                ]
            }
        },
        {
            "id": "page6",
            "speaker": "silver",
            "lines": [
                "Solo me importan los Pokémon fuertes que pueden ganar."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page7');"
                    }
                ]
            }
        },
        {
            "id": "page7",
            "speaker": "silver",
            "lines": [
                "Los Pokémon débiles me importan un comino."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Close",
                        "value": "close",
                        "action": [
                            "q.dialogue.close();",
                            "q.run_command('scoreboard players set ' + q.player.username + ' BattleStart 0');",
                            "q.run_command('execute as ' + q.player.username + ' run function johto:tools/forceclick');",
                            "q.run_command('tag ' + q.player.username + ' add Dialogue9');",
                            "q.run_command('tag ' + q.player.username + ' remove InDialogue');",
                            "q.run_command('scoreboard players set ' + q.player.username + ' TriggerCommand 91');"
                            ]
                    }
                ]
            }
        }
        ]
    }