{   "initializationAction": [              
    "q.run_command('scoreboard players set ' + q.player.username + ' BattleStart 1');",
    "q.run_command('execute as ' + q.player.username + ' run function johto:tools/forceclick');",
    "q.run_command('tag ' + q.player.username + ' add InDialogue');"
        ],
    "escapeAction": [              
        ],
    "speakers": {
        "npc": {
          "name": "Silver",
          "face": {
            "type": "artificial",
            "modelType": "npc",
            "identifier": "cobblemon:silver",
            "isLeftSide": true
          }
        }
      },
    "pages": [
        {
            "id": "greeting",
            "speaker": "npc",
            "lines": [
                "¿Cómo? ¿Cómo es posible? ¿Cómo puedo perder ante unas simples Kimono Girls?"
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page2');"
                    }
                ]
            }
        },
        {
            "id": "page2",
            "speaker": "npc",
            "lines": [
                {
                    "type": "expression",
                    "expression": "'¿Me estabas observando, ' + q.player.username + '?';"
                }
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page3');"
                    }
                ]
            }
        },
        {
            "id": "page3",
            "speaker": "npc",
            "lines": [
                "¡Sí, así es! ¡Nunca pensé que derrotar a cinco Kimono Girls sería tan difícil!"
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page4');"
                    }
                ]
            }
        },
        {
            "id": "page4",
            "speaker": "npc",
            "lines": [
                "Me dieron una paliza... ¡No te creas la gran cosa solo porque derrotaste al Team Rocket!"
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page5');"
                    }
                ]
            }
        },
        {
            "id": "page5",
            "speaker": "npc",
            "lines": [
                "¡Adelante! Pero yo no voy a volver."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page6');"
                    }
                ]
            }
        },
        {
            "id": "page6",
            "speaker": "npc",
            "lines": [
                "No quiero verte ganar. Estas Kimono Girls son increíblemente fuertes."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Close",
                        "value": "close",
                        "action": [
                            "q.dialogue.close();",
                            "q.run_command('scoreboard players set ' + q.player.username + ' BattleStart 0');",
                            "q.run_command('execute as ' + q.player.username + ' run function johto:tools/forceclick');",
                            "q.run_command('tag ' + q.player.username + ' add Dialogue31');",
                            "q.run_command('tag ' + q.player.username + ' remove InDialogue');",
                            "q.run_command('scoreboard players set ' + q.player.username + ' TriggerCommand 90');"
                            ]
                    }
                ]
            }
        }
        ]
    }