{   "initializationAction": [              
    "q.run_command('scoreboard players set ' + q.player.username + ' BattleStart 1');",
    "q.run_command('execute as ' + q.player.username + ' run function johto:tools/forceclick');",
    "q.run_command('tag ' + q.player.username + ' add InDialogue');"
        ],
    "escapeAction": [              
        ],
    "speakers": {
        "npc": {
          "name": "Silver",
          "face": {
            "type": "artificial",
            "modelType": "npc",
            "identifier": "cobblemon:silver",
            "isLeftSide": true
          }
        }
      },
    "pages": [
        {
            "id": "greeting",
            "speaker": "npc",
            "lines": [
                "¿Tú otra vez? No hace falta que te pongas en guardia. No pierdo el tiempo con debiluchos como tú."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page2');"
                    }
                ]
            }
        },
        {
            "id": "page2",
            "speaker": "npc",
            "lines": [
                "Hablando de debiluchos, el Líder de Gimnasio de la ciudad no está aquí, y al parecer está cuidando a un Pokémon enfermo en el Faro."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page3');"
                    }
                ]
            }
        },
        {
            "id": "page3",
            "speaker": "npc",
            "lines": [
                "¡Bah! ¡Bua-bua! ¡Deja ir a los Pokémon enfermos y ya!"
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page4');"
                    }
                ]
            }
        },
        {
            "id": "page4",
            "speaker": "npc",
            "lines": [
                "¡Un Pokémon que no puede combatir no vale nada!"
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page5');"
                    }
                ]
            }
        },
        {
            "id": "page5",
            "speaker": "npc",
            "lines": [
                "¿Por qué no vas a entrenar al Faro?"
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page6');"
                    }
                ]
            }
        },
        {
            "id": "page6",
            "speaker": "npc",
            "lines": [
                "¿Quién sabe? ¡Quizá te haga un Entrenador un poco mejor!"
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Close",
                        "value": "close",
                        "action": [
                            "q.dialogue.close();",
                            "q.run_command('scoreboard players set ' + q.player.username + ' BattleStart 0');",
                            "q.run_command('execute as ' + q.player.username + ' run function johto:tools/forceclick');",
                            "q.run_command('tag ' + q.player.username + ' add Dialogue39');",
                            "q.run_command('tag ' + q.player.username + ' remove InDialogue');",
                            "q.run_command('scoreboard players set ' + q.player.username + ' TriggerCommand 92');"
                            ]
                    }
                ]
            }
        }
        ]
    }