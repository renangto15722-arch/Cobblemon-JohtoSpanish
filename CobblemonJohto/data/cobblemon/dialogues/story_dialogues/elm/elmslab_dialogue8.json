{
    "initializationAction": [
        "q.run_command('tag ' + q.player.username + ' add InDialogue');"
    ],
    "escapeAction": [              
        ],

    "names": [
        "Professor Elm"
    ],
    "speakers": {
        "elm": {
            "name": "Professor Elm",
            "face": {
                "type": "artificial",
                "modelType": "npc",
                "identifier": "cobblemon:professorelm",
                "isLeftSide": true
            }
        },
        "aide": {
            "name": "Elm's Aide",
            "face": {
                "type": "artificial",
                "modelType": "npc",
                "identifier": "cobblemon:scientistm",
                "isLeftSide": false
            }
        },
        "police": {
            "name": "Policeman",
            "face": {
                "type": "artificial",
                "modelType": "npc",
                "identifier": "cobblemon:policeman",
                "isLeftSide": true
            }
        }
    },
    "pages": [
        {
            "id": "greeting",
            "speaker": "aide",
            "lines": [
                "Hubo un fuerte ruido afuera... Cuando fuimos a mirar, alguien había robado un Pokémon."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page2');"
                    }
                ]
            }
        },
        {
            "id": "page2",
            "speaker": "aide",
            "lines": [
                "¡Es increíble que alguien haga algo así!"
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page4');"
                    }
                ]
            }
        }, 
        {
            "id": "page4",
            "speaker": "aide",
            "lines": [
                "...suspiro... Ese Pokémon robado. Me pregunto cómo estará."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page5');"
                    }
                ]
            }
        },   
        {
            "id": "page5",
            "speaker": "aide",
            "lines": [
                "Dicen que un Pokémon criado por una mala persona se vuelve malo también."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page6');"
                    }
                ]
            }
        },   

        {
            "id": "page6",
            "speaker": "police",
            "lines": [
                "Oí que robaron un Pokémon aquí..."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page7');"
                    }
                ]
            }
        },   
        {
            "id": "page7",
            "speaker": "police",
            "lines": [
                "Justo estaba obteniendo algo de información del Profesor Elm."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page8');"
                    }
                ]
            }
        },   
        {
            "id": "page8",
            "speaker": "police",
            "lines": [
                "Al parecer, fue un joven de cabello largo y rojo..."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page9');"
                    }
                ]
            }
        },   
        {
            "id": "page9",
            "speaker": "police",
            "lines": [
                "¿Qué? ¿Luchaste contra un entrenador así? ¿Por casualidad supiste su nombre?"
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page10');"
                    }
                ]
            }
        },   
        {
            "id": "page10",
            "speaker": "police",
            "lines": [
                "... ... ..."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page11');"
                    }
                ]
            }
        },   
        {
            "id": "page11",
            "speaker": "police",
            "lines": [
                "Así que Silver era su nombre. ¡Gracias por ayudar en mi investigación!"
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": [
                            "q.run_command('execute as ' + q.player.username + ' run scoreboard players set @s TriggerCommand 88');",
                            "q.dialogue.set_page('page12');"
                        ]
                    }
                ]
            }
        },   


        {
            "id": "page12",
            "speaker": "elm",
            "lines": [
        {
            "type": "expression",
            "expression": "'' + q.player.username + ', esto es terrible...';"
        }
    ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page13');"
                    }
                ]
            }
        },  
        {
            "id": "page13",
            "speaker": "elm",
            "lines": [
                "Ah, sí, ¿cuál fue el gran descubrimiento de Mr. Pokémon?"
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": [
                            "q.run_command('execute as ' + q.player.username + ' run clear @s minecraft:turtle_egg');",
                            "q.dialogue.set_page('page14');"
                        ]
                    }
                ]
            }
        },   
        {
            "id": "page14",
            "speaker": "elm",
            "lines": [
                "¿Esto? Pero... ¿Es un Huevo Pokémon?"
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page15');"
                    }
                ]
            }
        },  
        {
            "id": "page15",
            "speaker": "elm",
            "lines": [
                "¡Si lo es, es un gran descubrimiento!"
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page16');"
                    }
                ]
            }
        },  
        {
            "id": "page16",
            "speaker": "elm",
            "lines": [
                "¿¡¿Qué?!? ¿El Profesor Oak te dio una Pokédex?"
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page17');"
                    }
                ]
            }
        },  
        {
            "id": "page17",
            "speaker": "elm",
            "lines": [
        {
            "type": "expression",
            "expression": "'' + q.player.username + ', ¿es eso cierto? ¡Es-eso es increíble!';"
        }
    ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page18');"
                    }
                ]
            }
        },  
        {
            "id": "page18",
            "speaker": "elm",
            "lines": [
                "Es excelente para ver el potencial de las personas como entrenadores."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page19');"
                    }
                ]
            }
        },  
        {
            "id": "page19",
            "speaker": "elm",
            "lines": [
        {
            "type": "expression",
            "expression": "'Vaya, ' + q.player.username + ', puede que tengas lo necesario para convertirte en Campeón.';"
        }
    ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page20');"
                    }
                ]
            }
        },  
        {
            "id": "page20",
            "speaker": "elm",
            "lines": [
                "Parece que también te llevas muy bien con los Pokémon."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page21');"
                    }
                ]
            }
        },  
        {
            "id": "page21",
            "speaker": "elm",
            "lines": [
                "Deberías aceptar el reto del Gimnasio Pokémon."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page22');"
                    }
                ]
            }
        },  
        {
            "id": "page22",
            "speaker": "elm",
            "lines": [
                "El Gimnasio más cercano sería el de Ciudad Malva."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page23');"
                    }
                ]
            }
        },  
        {
            "id": "page23",
            "speaker": "elm",
            "lines": [
        {
            "type": "expression",
            "expression": "'... ' + q.player.username + '. El camino hacia el campeonato será largo.';"
        }
    ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page24');"
                    }
                ]
            }
        },  
        {
            "id": "page24",
            "speaker": "elm",
            "lines": [
                "Antes de irte, asegúrate de hablar con tu mamá."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page25');"
                    }
                ]
            }
        },  






        {
            "id": "page25",
            "speaker": "aide",
            "lines": [
        {
            "type": "expression",
            "expression": "'' + q.player.username + '! ¡Úsalas en tu búsqueda de la Pokédex!';"
        }
    ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page26');"
                    }
                ]
            }
        },
        {
            "id": "page26",
            "speaker": "aide",
            "lines": [
                "Para completar tu Pokédex, tienes que capturar Pokémon."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page27');"
                    }
                ]
            }
        },
        {
            "id": "page27",
            "speaker": "aide",
            "lines": [
                "Lanza Poké Balls a los Pokémon salvajes para atraparlos."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Close",
                        "value": "close",
                        "action": [
                            "q.run_command('execute as ' + q.player.username + ' run give @s cobblemon:poke_ball 5');",
                            "q.run_command('execute as ' + q.player.username + ' run playsound minecraft:entity.experience_orb.pickup ambient @s ~ ~ ~ 1 1 1');",
                            "q.run_command('tag ' + q.player.username + ' add Dialogue8');",
                            "q.run_command('tag ' + q.player.username + ' remove InDialogue');",
                            "q.dialogue.close();"
                        ]
                    }
                ]
            }
        }
    ]
}