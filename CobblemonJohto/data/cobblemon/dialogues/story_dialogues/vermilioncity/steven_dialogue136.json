{
    "initializationAction": [
        "q.run_command('tag ' + q.player.username + ' add InDialogue');"
    ],
    "escapeAction": [],
    "speakers": {
        "npc": {
            "name": "Steven",
            "face": {
                "type": "artificial",
                "modelType": "npc",
                "identifier": "cobblemon:steven",
                "isLeftSide": true
            }
        },
        "player": {
            "face": "q.player.face(true);",
            "name": {
                "type": "expression",
                "expression": "q.player.username"
            }
        }
    },
    "pages": [
        {
            "id": "greeting",
            "speaker": "npc",
            "lines": [
                "¡Hola! Me llamo Steven. El Campeón de la región de Hoenn."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page2');"
                    }
                ]
            }
        },
        {
            "id": "page2",
            "speaker": "npc",
            "lines": [
                "¿Nos hemos visto... antes?"
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page3');"
                    }
                ]
            }
        },
        {
            "id": "page3",
            "speaker": "npc",
            "lines": [
                "No es posible. De todos modos, todos los Entrenadores contra los que he luchado parecen tener la misma mirada."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": [
                            "q.dialogue.set_page('page4');"
                        ]
                    }
                ]
            }
        },
        {
            "id": "page4",
            "speaker": "npc",
            "lines": [
                "Especialmente los que me dieron batallas difíciles..."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": [
                            "q.dialogue.set_page('page5');"
                        ]
                    }
                ]
            }
        },
        {
            "id": "page5",
            "speaker": "npc",
            "lines": [
                "Por cierto, ¿has oído hablar de unos Pokémon llamados Latias y Latios?"
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": [
                            "q.dialogue.set_page('page6');"
                        ]
                    }
                ]
            }
        },
        {
            "id": "page6",
            "speaker": "npc",
            "lines": [
                "Estoy investigando por qué Latias y Latios, Pokémon de Hoenn, decidieron dejar Hoenn para venir aquí."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": [
                            "q.dialogue.set_page('page7');"
                        ]
                    }
                ]
            }
        },
        {
            "id": "page7",
            "speaker": "npc",
            "lines": [
                "Latias y Latios son Pokémon que tienen mucho que ver con la Soul Dew, un Orbe similar a una gema."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": [
                            "q.dialogue.set_page('page8');"
                        ]
                    }
                ]
            }
        },
        {
            "id": "page8",
            "speaker": "npc",
            "lines": [
                "Considerando que Latias y Latios están ahora en Kanto, es posible suponer que esto tiene que ver con la Soul Dew."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": [
                            "q.dialogue.set_page('page9');"
                        ]
                    }
                ]
            }
        },
        {
            "id": "page9",
            "speaker": "npc",
            "lines": [
                "Latias y Latios son Pokémon que viajan grandes distancias."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": [
                            "q.dialogue.set_page('page10');"
                        ]
                    }
                ]
            }
        },
        {
            "id": "page10",
            "speaker": "npc",
            "lines": [
                "Pero cualquier Entrenador se sentirá atraído por ellos, ¿no?"
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": [
                            "q.dialogue.set_page('page11');"
                        ]
                    }
                ]
            }
        },
        {
            "id": "page11",
            "speaker": "npc",
            "lines": [
                "Debo irme. Que nuestros caminos se crucen de nuevo."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Close",
                        "value": "close",
                        "action": [
                            "q.run_command('tp @e[x=-2710,y=63,z=-55,dy=3,dz=1,type=cobblemon:npc] 10000000 -50000 -10000000');",
                            "q.run_command('particle cloud -2710 64 -55 1 1 1 1 100');",
                            "q.dialogue.set_page('page12');"
                        ]
                    }
                ]
            }
        },
        {
            "id": "page12",
            "speaker": "player",
            "lines": [
                "¡Ahora puedes encontrar a Latios y Latias en cualquier momento en la hierba salvaje!"
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Close",
                        "value": "close",
                        "action": [
                            "q.run_command('execute as ' + q.player.username + ' run advancement grant @s only johto:event5');",
                            "q.run_command('tag ' + q.player.username + ' add Dialogue136');",
                            "q.run_command('tag ' + q.player.username + ' add StevenCooldown');",
                            "q.run_command('tag ' + q.player.username + ' remove InDialogue');",
                            "q.dialogue.close();"
                        ]
                    }
                ]
            }
        }
    ]
}