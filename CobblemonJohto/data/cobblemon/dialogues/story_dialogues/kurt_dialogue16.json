{
    "initializationAction": [
        "q.run_command('tag ' + q.player.username + ' add InDialogue');",
        "q.run_command('scoreboard players set ' + q.player.username + ' BattleEnd 2');",
    "q.run_command('execute as ' + q.player.username + ' run function johto:tools/forceclick');"
    ],
    "escapeAction": [],
    "speakers": {
        "kurt": {
            "name": "Kurt",
            "face": {
                "type": "artificial",
                "modelType": "npc",
                "identifier": "cobblemon:kurt",
                "isLeftSide": true
            }
        },
        "proton": {
            "name": "Team Rocket Proton",
            "face": {
                "type": "artificial",
                "modelType": "npc",
                "identifier": "cobblemon:proton",
                "isLeftSide": false
            }
        }
    },
    "pages": [
        {
            "id": "greeting",
            "speaker": "proton",
            "lines": [
                "Sí, el Team Rocket se disolvió hace tres años."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page2');"
                    }
                ]
            }
        },
        {
            "id": "page2",
            "speaker": "proton",
            "lines": [
                "Pero continuamos nuestras actividades en la clandestinidad."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page3');"
                    }
                ]
            }
        },
        {
            "id": "page3",
            "speaker": "proton",
            "lines": [
                "¡Ahora puedes divertirte viéndonos causar problemas!"
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": [
                            "q.run_command('execute as ' + q.player.username + ' run scoreboard players set @s TriggerCommand 86');",
                            "q.dialogue.set_page('page4');"
                        ]
                    }
                ]
            }
        },
        {
            "id": "page4",
            "speaker": "kurt",
            "lines": [
                {
                    "type": "expression",
                    "expression": "'¡Bien hecho, ' + q.player.username + '!';"
                }
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page5');"
                    }
                ]
            }
        },
        {
            "id": "page5",
            "speaker": "kurt",
            "lines": [
                "El Team Rocket se largó. Mi espalda también está mejor."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": [
                            "q.dialogue.set_page('page6');"
                        ]
                    }
                ]
            }
        },
        {
            "id": "page6",
            "speaker": "kurt",
            "lines": [
                "Salgamos de aquí."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": [
                            "q.dialogue.set_page('page7');",
                            "q.run_command('execute as ' + q.player.username + ' run scoreboard players set @s TriggerCommand 87');",
                            "q.run_command('execute as ' + q.player.username + ' run scoreboard players set @s Farfetchd 0');",
                            "q.run_command('execute as ' + q.player.username + ' run advancement grant @s only johto:story/rocket1');"
                        ]
                    }
                ]
            }
        },
        {
            "id": "page7",
            "speaker": "kurt",
            "lines": [
                "Te comportaste como un verdadero héroe en el Pozo."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": [
                            "q.dialogue.set_page('page9');"
                        ]
                    }
                ]
            }
        },
        {
            "id": "page9",
            "speaker": "kurt",
            "lines": [
                "¡Me gusta tu estilo! Sería un honor fabricar Balls para un entrenador como tú."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": [
                            "q.dialogue.set_page('page10');"
                        ]
                    }
                ]
            }
        },
        {
            "id": "page10",
            "speaker": "kurt",
            "lines": [
                "Esto es todo lo que tengo ahora, pero tómalo."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": [
                            "q.dialogue.set_page('page11');",
                            "q.run_command('execute as ' + q.player.username + ' run give @s cobblemon:fast_ball 5');",
                            "q.run_command('execute as ' + q.player.username + ' run playsound minecraft:entity.experience_orb.pickup ambient @s ~ ~ ~ 1 1 1');"
                        ]
                    }
                ]
            }
        },
        {
            "id": "page11",
            "speaker": "kurt",
            "lines": [
                "Hago Balls con Apricorns."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": [
                            "q.dialogue.set_page('page12');"
                        ]
                    }
                ]
            }
        },
        {
            "id": "page12",
            "speaker": "kurt",
            "lines": [
                "Recógelas de los árboles y tráelas a mis bancos de trabajo. ¡Haremos Balls con ellas!"
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Close",
                        "value": "close",
                        "action": [
                            "q.run_command('tag ' + q.player.username + ' add Dialogue16');",
                            "q.run_command('tag ' + q.player.username + ' remove InDialogue');",
                            "q.dialogue.close();"
                        ]
                    }
                ]
            }
        }
    ]
}