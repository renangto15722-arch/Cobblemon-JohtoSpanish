{
    "initializationAction": [
        "q.run_command('tag ' + q.player.username + ' add InDialogue');"
    ],
    "escapeAction": [],
    "speakers": {
        "lance": {
            "name": "Lance",
            "face": {
                "type": "artificial",
                "modelType": "npc",
                "identifier": "cobblemon:lance",
                "isLeftSide": true
            }
        },
        "ariana": {
            "name": "Ariana",
            "face": {
                "type": "artificial",
                "modelType": "npc",
                "identifier": "cobblemon:ariana",
                "isLeftSide": false
            }
        }
    },
    "pages": [
        {
            "id": "greeting",
            "speaker": "lance",
            "lines": [
                "¡Oye! No seas tan egoísta. Comparte la diversión."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page2');"
                    }
                ]
            }
        },
        {
            "id": "page2",
            "speaker": "ariana",
            "lines": [
                "¿Qué? ¿Tenías un cómplice? ¿Dónde está tu sentido del honor?"
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": [
                            "q.dialogue.set_page('page3');"
                        ]
                    }
                ]
            }
        },
        {
            "id": "page3",
            "speaker": "ariana",
            "lines": [
                "¡Como jefa interina en lugar de Giovanni, te mostraré lo equivocado que es meterse con el Team Rocket!"
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Close",
                        "value": "close",
                        "action": [
                            "q.run_command('tag ' + q.player.username + ' add Dialogue61');",
                            "q.run_command('tag ' + q.player.username + ' remove InDialogue');",
                            "q.dialogue.close();"
                        ]
                    }
                ]
            }
        }
    ]
}