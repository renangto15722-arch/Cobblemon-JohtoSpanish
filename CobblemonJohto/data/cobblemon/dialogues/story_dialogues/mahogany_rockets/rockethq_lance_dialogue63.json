        {
            "id": "page5",
            "speaker": "lance",
            "lines": [
                {
                    "type": "expression",
                    "expression": "'No es culpa de los Pokémon, así que me hace sentir culpable. ' + q.player.username + ', dividamos el trabajo.';"
