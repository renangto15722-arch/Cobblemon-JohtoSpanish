                ]
            }
        },
        {
            "id": "page2",
            "speaker": "npc",
            "lines": [
                {
                    "type": "expression",
                    "expression": "'¿Eres ' + q.player.username + '? Soy Lance, un entrenador como tú.';"
                }
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page3');"
