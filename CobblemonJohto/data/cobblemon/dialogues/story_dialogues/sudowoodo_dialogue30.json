{
    "initializationAction": [
        "q.run_command('tag ' + q.player.username + ' add InDialogue');"
    ],
    "escapeAction": [],
    "speakers": {
        "player": {
            "face": "q.player.face(true);",
            "name": {
           "type": "expression",
           "expression": "q.player.username"
         }
       },
        "sudowoodo": {
      "name": "Weird Tree",
      "face": {
        "type": "artificial",
        "modelType": "pokemon",
        "identifier": "cobblemon:sudowoodo",
        "isLeftSide": false
      }
    }
    },
    "pages": [
        {
            "id": "greeting",
            "speaker": "player",
            "lines": [
                "Es un árbol raro."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page2');"
                    }
                ]
            }
        },
        {
            "id": "page2",
            "speaker": "player",
            "lines": [
                {
                    "type": "expression",
                    "expression": "'' + q.player.username + ' usó la Squirtbottle.';"
                }
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page3');"
                    }
                ]
            }
        },
        {
            "id": "page3",
            "speaker": "sudowoodo",
            "lines": [
                "¡Al árbol raro no le gusta la Squirtbottle!"
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page4');"
                    }
                ]
            }
        },
        {
            "id": "page4",
            "speaker": "sudowoodo",
            "lines": [
                "¡El árbol raro atacó!"
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Close",
                        "value": "close",
                        "action": [
                            "q.run_command('execute as ' + q.player.username + ' run scoreboard players set @s TriggerCommand 10');",
                            "q.run_command('tag ' + q.player.username + ' add Dialogue30');",
                            "q.run_command('tag ' + q.player.username + ' remove InDialogue');",
                            "q.dialogue.close();"
                        ]
                    }
                ]
            }
        }
    ]
}