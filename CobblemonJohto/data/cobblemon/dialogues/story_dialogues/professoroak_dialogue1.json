            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page6');"
                    }
                ]
            }
        },
        {
            "id": "page6",
            "speaker": "npc",
            "lines": [
                "Algunas personas juegan con los Pokémon, otras combaten con ellos."
