{
    "initializationAction": [
        "q.run_command('tag ' + q.player.username + ' add InDialogue');",
        "q.run_command('execute as ' + q.player.username + ' run particle cloud -688 74 540 1 1 1 1 100');",
        "q.run_command('execute as ' + q.player.username + ' run npcspawnat -688 74 540 dragonsden_clair');"
    ],
    "escapeAction": [],
    "speakers": {
        "npc": {
            "name": "Clair",
            "face": {
                "type": "artificial",
                "modelType": "npc",
                "identifier": "cobblemon:clair",
                "isLeftSide": true
            }
        }
    },
    "pages": [
        {
            "id": "greeting",
            "speaker": "npc",
            "lines": [
                "De acuerdo. Reconozco tu verdadero poder. Esta Medalla es tuya."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": [
                            "q.run_command('execute as ' + q.player.username + ' run stopsound @s record');",
                            "q.run_command('execute as ' + q.player.username + ' run playsound badge ambient @s ~ ~ ~ 1 1 1');",
                            "q.run_command('execute as ' + q.player.username + ' run scoreboard players set @s click 1');",
                            "q.run_command('execute as ' + q.player.username + ' run advancement grant @s only johto:badges/badge8');",
                            "q.run_command('execute as ' + q.player.username + ' run tag @s add Clair');",
                            "q.dialogue.set_page('page2');"
                    ]
                    }
                ]
            }
        },
        {
            "id": "page2",
            "speaker": "npc",
            "lines": [
                "Así que has reunido todas las Medallas."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page3');"
                    }
                ]
            }
        },
        {
            "id": "page3",
            "speaker": "npc",
            "lines": [
                "Tu destino es la Liga Pokémon en la Meseta Añil."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": [
                        "q.dialogue.set_page('page4');"
                    ]
                    }
                ]
            }
        },
        {
            "id": "page3",
            "speaker": "npc",
            "lines": [
                "¿Sabes cómo llegar allí?"
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": [
                        "q.dialogue.set_page('page4');"
                    ]
                    }
                ]
            }
        },
        {
            "id": "page4",
            "speaker": "npc",
            "lines": [
                "Desde aquí, ve a Pueblo Primavera. Luego surfea hacia el este."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": [
                        "q.dialogue.set_page('page5');"
                    ]
                    }
                ]
            }
        },
        {
            "id": "page5",
            "speaker": "npc",
            "lines": [
                "El camino hasta allí es muy difícil."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": [
                        "q.dialogue.set_page('page6');"
                    ]
                    }
                ]
            }
        },
        {
            "id": "page6",
            "speaker": "npc",
            "lines": [
                "¡No te atrevas a perder en la Liga Pokémon!"
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": [
                        "q.dialogue.set_page('page7');"
                    ]
                    }
                ]
            }
        },
        {
            "id": "page7",
            "speaker": "npc",
            "lines": [
                "¡Si lo haces, me sentiré aún peor por haber perdido contra ti!"
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Close",
                        "value": "close",
                        "action": [
                            "q.run_command('execute as ' + q.player.username + ' run particle cloud -688 74 540 1 1 1 1 100');",
                            "q.run_command('execute as ' + q.player.username + ' run tp @e[x=-688,y=74,z=540,distance=..3,type=cobblemon:npc] 10000000 -50000 -10000000');",
                            "q.run_command('tag ' + q.player.username + ' add Dialogue79');",
                            "q.run_command('tag ' + q.player.username + ' remove InDialogue');",
                            "q.dialogue.close();"
                        ]
                    }
                ]
            }
        }
    ]
