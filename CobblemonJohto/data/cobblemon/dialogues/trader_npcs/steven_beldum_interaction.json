{
    "speakers": {
        "npc": {
            "name": "Steven",
            "face": {
                "type": "artificial",
                "modelType": "npc",
                "identifier": "cobblemon:steven",
                "isLeftSide": true
            }
        },
        "player": {
            "face": "q.player.face();",
            "name": {
                "type": "expression",
                "expression": "q.player.username"
            }
        }
    },
    "pages": [
        {
            "id": "greeting",
            "speaker": "npc",
            "lines": [
                "We meet again! Have you been to Hoenn before?"
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page2');"
                    }
                ]
            }
        },
        {
            "id": "page2",
            "speaker": "npc",
            "lines": [
                "It's such a beautiful place, with the clearest ocean you can imagine. You should visit sometime."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page3');"
                    }
                ]
            }
        },
        {
            "id": "page3",
            "speaker": "npc",
            "lines": [
                "Hey! Why don't we trade Pokémon?"
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page4');"
                    }
                ]
            }
        },
        {
            "id": "page4",
            "speaker": "npc",
            "lines": [
                "I've been looking for Forretress. I can trade my Beldum for it."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Yes",
                        "value": "yes",
                        "isSelectable": "q.player.party.count_by_properties(q.npc.config.trade_requested) >= 1",
                        "action": "q.dialogue.set_page('confirmation');"
                    },
                    {
                        "text": "No",
                        "value": "no",
                        "action": "q.dialogue.set_page('okbye');"
                    }
                ]
            }
        },
        {
            "id": "confirmation",
            "speaker": "npc",
            "lines": [
                "OK, let's trade!"
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "§b🔁 Trade 🔁§r",
                        "value": "trade",
                        "isSelectable": "q.player.party.count_by_properties(q.npc.config.trade_requested) >= 1",
                        "action": [
                            "q.run_script('pt_trade_pkmn');",
                            "q.dialogue.close();"
                        ]
                    },
                    {
                        "text": "No",
                        "value": "no",
                        "action": "q.dialogue.set_page('okbye');"
                    }
                ]
            }
        },
        {
            "id": "okbye",
            "speaker": "npc",
            "lines": [
                "That's too bad."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Close",
                        "value": "close",
                        "action": [
                            "q.dialogue.close();"
                        ]
                    }
                ]
            }
        }
    ]
}