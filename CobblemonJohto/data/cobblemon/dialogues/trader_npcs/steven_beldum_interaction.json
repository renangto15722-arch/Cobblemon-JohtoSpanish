{
    "speakers": {
        "npc": {
            "name": "Steven",
            "face": {
                "type": "artificial",
                "modelType": "npc",
                "identifier": "cobblemon:steven",
                "isLeftSide": true
            }
        },
        "player": {
            "face": "q.player.face();",
            "name": {
                "type": "expression",
                "expression": "q.player.username"
            }
        }
    },
    "pages": [
        {
            "id": "greeting",
            "speaker": "npc",
            "lines": [
                "¡Nos encontramos de nuevo! ¿Has estado antes en Hoenn?"
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page2');"
                    }
                ]
            }
        },
        {
            "id": "page2",
            "speaker": "npc",
            "lines": [
                "Es un lugar precioso, con el océano más cristalino que puedas imaginar. Deberías visitarlo alguna vez."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page3');"
                    }
                ]
            }
        },
        {
            "id": "page3",
            "speaker": "npc",
            "lines": [
                "¡Oye! ¿Por qué no intercambiamos Pokémon?"
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page4');"
                    }
                ]
            }
        },
        {
            "id": "page4",
            "speaker": "npc",
            "lines": [
                "He estado buscando un Forretress. Puedo intercambiar mi Beldum por él."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Yes",
                        "value": "yes",
                        "isSelectable": "q.player.party.count_by_properties(q.npc.config.trade_requested) >= 1",
                        "action": "q.dialogue.set_page('confirmation');"
                    },
                    {
                        "text": "No",
                        "value": "no",
                        "action": "q.dialogue.set_page('okbye');"
                    }
                ]
            }
        },
        {
            "id": "confirmation",
            "speaker": "npc",
            "lines": [
                "¡Vale, intercambiemos!"
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "§b🔁 Trade 🔁§r",
                        "value": "trade",
                        "isSelectable": "q.player.party.count_by_properties(q.npc.config.trade_requested) >= 1",
                        "action": [
                            "q.run_script('pt_trade_pkmn');",
                            "q.dialogue.close();"
                        ]
                    },
                    {
                        "text": "No",
                        "value": "no",
                        "action": "q.dialogue.set_page('okbye');"
                    }
                ]
            }
        },
        {
            "id": "okbye",
            "speaker": "npc",
            "lines": [
                "Qué lástima."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Close",
                        "value": "close",
                        "action": [
                            "q.dialogue.close();"
                        ]
                    }
                ]
            }
        }
    ]
}