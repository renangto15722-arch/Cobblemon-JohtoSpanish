{
  "initializationAction": "c.npc.set_chatting();",
  "speakers": {
    "npc": {
      "name": {
        "type": "expression",
        "expression": "q.npc.name"
      },
      "face": "q.npc.face();"
    }
  },
  "pages": [
    {
      "id": "greeting",
      "speaker": "npc",
      "lines": ["Gracias por esperar. ¡Esperamos verte de nuevo!"],
      "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Close",
                        "value": "close",
                        "action": "q.dialogue.close();"
                    }
                ]
            }
    }
  ]
}