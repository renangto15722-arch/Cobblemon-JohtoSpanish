{
  "initializationAction": [
    "c.npc.set_chatting();",
    "v.healer = c.npc.find_nearby_block('cobblemon:healing_machine');",
    "v.has_healer = v.healer != 0;",
    "v.full_health = c.player.is_party_at_full_health();",
    "v.has_charge = v.has_healer == true && v.full_health == false && q.player.can_heal_at_healer(v.healer) == true;",
    "v.landing_page = !v.has_healer ? 'no_healer' : (v.full_health ? 'full_health' : (v.has_charge ? 'has_charge' : 'no_charge'));"
  ],
  "speakers": {
    "npc": {
      "name": "Nurse Joy",
      "face": "q.npc.face();"
    },
    "player": {
      "face": "q.player.face();",
      "name": {
        "type": "expression",
        "expression": "q.player.username"
      }
    }
  },
  "pages": [
    {
      "id": "greeting",
      "speaker": "npc",
      "lines": ["Hola, y bienvenido al Centro Pokémon. Devolvemos a tus Pokémon cansados a su plena salud."],
      "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page(v.landing_page);"
                    }
                ]
            }
    },
    {
      "id": "no_healer",
      "speaker": "npc",
      "lines": ["Me ofrecería a curar a tus Pokémon, pero no encuentro mi máquina de curación...", "¡Lo siento mucho!"],
      "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Close",
                        "value": "close",
                        "action": "q.dialogue.close();"
                    }
                ]
            }
    },
    {
      "id": "full_health",
      "speaker": "npc",
      "lines": ["Me ofrecería a curar a tus Pokémon, ¡pero tus Pokémon están completamente sanos!"],
      "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Close",
                        "value": "close",
                        "action": "q.dialogue.close();"
                    }
                ]
            }
    },
    {
      "id": "no_charge",
      "speaker": "npc",
      "lines": ["¡Me gustaría curar a tus Pokémon pero mi máquina está ocupada! ¡Por favor vuelve más tarde!"],
      "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Close",
                        "value": "close",
                        "action": "q.dialogue.close();"
                    }
                ]
            }
    },
    {
      "id": "has_charge",
      "speaker": "npc",
      "lines": ["¿Te gustaría que tus Pokémon descansen?"],
      "input": {
        "type": "option",
        "vertical": false,
        "options": [
          {
            "text": "Yes",
            "value": "yes",
            "action": [
              "v.callback_dialogue = 'nursejoy_healed';",
              "c.npc.run_action_effect('npc_heal_player_pokemon');",
              "q.dialogue.close();"
            ]
          },
          {
            "text": "No",
            "value": "no",
            "action": "q.dialogue.set_page('okbye');"
          }
        ]
      }
    },
    {
      "id": "okbye",
      "speaker": "npc",
      "lines": ["¡Muy bien, hasta luego!"],
      "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Close",
                        "value": "close",
                        "action": "q.dialogue.close();"
                    }
                ]
            }
    }
  ]
}